{
  "$schema": "vscode://schemas/color-theme",
  "name": "simple-light",
  "type": "light",
  "colors": {
    // ---- 编辑器核心（最亮层级，柔和米白不刺眼）----
    "editor.background": "#fafafa",
    "editor.foreground": "#242424",
    "editorLineNumber.foreground": "#9e9e9e",
    "editorLineNumber.activeForeground": "#242424",
    "editor.lineHighlightBackground": "#f0f0f0",
    "editor.selectionBackground": "#d6e4ff",
    "editor.selectionHighlightBackground": "#e8f0ff",
    "editorCursor.foreground": "#0033b3",
    "editorWhitespace.foreground": "#e0e0e0",
    "editorIndentGuide.background": "#e8e8e8",
    "editorIndentGuide.activeBackground": "#c8c8c8",
    "editorRuler.foreground": "#e8e8e8",
    "editorBracketMatch.background": "#e8f0ff",
    "editorBracketMatch.border": "#0033b3",

    // ---- 侧边栏（文件栏，中间灰度层级）----
    "sideBar.background": "#f5f5f5",
    "sideBar.foreground": "#242424",
    "sideBarSectionHeader.background": "#eeeeee",
    "sideBarSectionHeader.foreground": "#242424",
    "sideBarTitle.foreground": "#242424",
    "sideBar.border": "#e8e8e8",

    // ---- 活动栏（稍暗，强化层级）----
    "activityBar.background": "#f0f0f0",
    "activityBar.foreground": "#242424",
    "activityBar.inactiveForeground": "#9e9e9e",
    "activityBar.border": "#e8e8e8",
    "activityBar.activeBorder": "#0033b3",
    "activityBar.activeBackground": "#f5f5f5",

    // ========== 顶部标题栏 偏暗中性灰做对比 ==========
    "titleBar.activeBackground": "#e8e8e8",
    "titleBar.activeForeground": "#242424",
    "titleBar.inactiveBackground": "#f0f0f0",
    "titleBar.inactiveForeground": "#777777",
    "titleBar.border": "#e0e0e0",

    "menu.background": "#f5f5f5",
    "menu.foreground": "#242424",
    "menu.selectionBackground": "#d6e4ff",
    "menu.selectionForeground": "#242424",
    "menu.border": "#e0e0e0",

    // ========== 底部状态栏 ==========
    "statusBar.background": "#f0f0f0",
    "statusBar.foreground": "#242424",
    "statusBar.border": "#e8e8e8",
    "statusBar.debuggingBackground": "#f5e0d0",

    // ---- 面板 / 终端（与侧边栏同层级，统一灰度）----
    "panel.background": "#f5f5f5",
    "panel.border": "#e8e8e8",
    "panelTitle.activeForeground": "#242424",
    "panelTitle.inactiveForeground": "#9e9e9e",

    "terminal.background": "#f5f5f5",
    "terminal.foreground": "#242424",
    "terminal.ansiBlack": "#1a1a1a",
    "terminal.ansiRed": "#b02b3d",
    "terminal.ansiGreen": "#216e39",
    "terminal.ansiYellow": "#b87333",
    "terminal.ansiBlue": "#0033b3",
    "terminal.ansiMagenta": "#8828a0",
    "terminal.ansiCyan": "#007095",
    "terminal.ansiWhite": "#c8c8c8",
    "terminal.ansiBrightBlack": "#777777",
    "terminal.ansiBrightRed": "#d13a4f",
    "terminal.ansiBrightGreen": "#2e9e4a",
    "terminal.ansiBrightYellow": "#d9923b",
    "terminal.ansiBrightBlue": "#1a56db",
    "terminal.ansiBrightMagenta": "#a035c2",
    "terminal.ansiBrightCyan": "#0090b8",
    "terminal.ansiBrightWhite": "#f0f0f0",

    // ---- 列表 / 树 ----
    "list.activeSelectionBackground": "#d6e4ff",
    "list.activeSelectionForeground": "#242424",
    "list.inactiveSelectionBackground": "#e8e8e8",
    "list.inactiveSelectionForeground": "#242424",
    "list.hoverBackground": "#eeeeee",
    "list.hoverForeground": "#242424",
    "list.focusBackground": "#d6e4ff",
    "list.focusForeground": "#242424",
    "list.highlightForeground": "#0033b3",

    // ---- 输入框 / 下拉 ----
    "input.background": "#ffffff",
    "input.foreground": "#242424",
    "input.border": "#e0e0e0",
    "input.placeholderForeground": "#9e9e9e",
    "dropdown.background": "#ffffff",
    "dropdown.foreground": "#242424",
    "dropdown.border": "#e0e0e0",

    // ---- 按钮 ----
    "button.background": "#e0e0e0",
    "button.foreground": "#242424",
    "button.hoverBackground": "#d0d0d0",

    // ---- 滚动条 ----
    "scrollbarSlider.background": "#d0d0d0",
    "scrollbarSlider.hoverBackground": "#c0c0c0",
    "scrollbarSlider.activeBackground": "#b0b0b0",

    // ---- 标签栏与分割线 ----
    "editorGroup.border": "#e8e8e8",
    "editorGroupHeader.tabsBackground": "#f5f5f5",
    "tab.activeBackground": "#fafafa",
    "tab.inactiveBackground": "#f5f5f5",
    "tab.activeForeground": "#242424",
    "tab.inactiveForeground": "#777777",
    "tab.border": "#e8e8e8",
    "tab.activeBorder": "#0033b3",

    // ---- 提示/通知 ----
    "notification.background": "#ffffff",
    "notification.foreground": "#242424",
    "notificationCenter.border": "#e8e8e8",
    "notificationToast.border": "#e8e8e8",

    // ---- 其他 ----
    "badge.background": "#0033b3",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#0033b3",
    "editorWidget.background": "#ffffff",
    "editorWidget.border": "#e8e8e8",
    "editor.findMatchBackground": "#fff3cd",
    "list.activeSelectionIconForeground": "#ffffff"
  },

  "tokenColors": [
    // ---------- 通用基础高亮（macOS 终端质感柔化版）----------
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5c8e4e"
      }
    },

    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.declaration",
        "keyword.package.go",
        "keyword.import.go",
        "keyword.function.go",
        "keyword.type.go",
        "keyword.struct.go",
        "keyword.interface.go",
        "keyword.map.go",
        "keyword.chan.go"
      ],
      "settings": {
        "foreground": "#0033b3"
      }
    },

    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "entity.name.function.go"
      ],
      "settings": {
        "foreground": "#b02b3d"
      }
    },

    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type.primitive",
        "entity.name.type.alias.go",
        "entity.name.type.struct.go",
        "entity.name.type.interface.go"
      ],
      "settings": {
        "foreground": "#0066cc"
      }
    },

    {
      "name": "Strings",
      "scope": "string",
      "settings": {
        "foreground": "#216e39"
      }
    },

    {
      "name": "Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.boolean",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#b87333"
      }
    },

    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#242424"
      }
    },

    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#333333"
      }
    },

    // ---------- JSON 文件专属高亮 ----------
    {
      "name": "JSON Property Key",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#0066cc"
      }
    },
    {
      "name": "JSON Constant",
      "scope": "constant.language.json",
      "settings": {
        "foreground": "#b02b3d"
      }
    },

    // ---------- SQL 文件专属高亮 ----------
    {
      "name": "SQL Keyword",
      "scope": [
        "keyword.sql",
        "keyword.ddl.sql",
        "keyword.dml.sql"
      ],
      "settings": {
        "foreground": "#0033b3"
      }
    },
    {
      "name": "SQL Built-in Function",
      "scope": "support.function.sql",
      "settings": {
        "foreground": "#b02b3d"
      }
    },
    {
      "name": "SQL Table Name",
      "scope": "entity.name.table.sql",
      "settings": {
        "foreground": "#0066cc"
      }
    },
    {
      "name": "SQL Column Name",
      "scope": "entity.name.column.sql",
      "settings": {
        "foreground": "#242424"
      }
    },

    // ---------- Markdown 文件专属高亮 ----------
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#0033b3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#b02b3d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#b87333",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link URL",
      "scope": "markup.link.url",
      "settings": {
        "foreground": "#216e39",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown Link Text",
      "scope": "string.other.link.title.markdown",
      "settings": {
        "foreground": "#0066cc"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#5c8e4e"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#b02b3d"
      }
    },
    {
      "name": "Markdown List Bullet",
      "scope": "punctuation.definition.list.markdown",
      "settings": {
        "foreground": "#0066cc"
      }
    }
  ]
}