{
  "$schema": "vscode://schemas/color-theme",
  "name": "Tsoding Emacs Dark (Gruber)",
  "type": "dark",
  "colors": {
    // ---- 编辑器核心 ----
    "editor.background": "#181818",
    "editor.foreground": "#e4e4e4",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editor.selectionBackground": "#3a3a3a",
    "editor.selectionHighlightBackground": "#2d2d2d",
    "editorCursor.foreground": "#f43753",
    "editorWhitespace.foreground": "#3a3a3a",
    "editorIndentGuide.background": "#2a2a2a",
    "editorIndentGuide.activeBackground": "#4a4a4a",
    "editorLineNumber.foreground": "#4a4a4a",
    "editorLineNumber.activeForeground": "#e4e4e4",
    "editorRuler.foreground": "#2a2a2a",
    "editorBracketMatch.background": "#2a2a2a",
    "editorBracketMatch.border": "#f43753",

    // ---- 侧边栏 ----
    "sideBar.background": "#151515",
    "sideBar.foreground": "#e4e4e4",
    "sideBarSectionHeader.background": "#1a1a1a",
    "sideBarSectionHeader.foreground": "#e4e4e4",
    "sideBarTitle.foreground": "#e4e4e4",
    "sideBar.border": "#181818",

    // ---- 活动栏 ----
    "activityBar.background": "#111111",
    "activityBar.foreground": "#e4e4e4",
    "activityBar.inactiveForeground": "#4a4a4a",
    "activityBar.border": "#181818",
    "activityBar.activeBorder": "#f43753",
    "activityBar.activeBackground": "#1a1a1a",

    // ---- 状态栏 ----
    "statusBar.background": "#111111",
    "statusBar.foreground": "#e4e4e4",
    "statusBar.border": "#181818",
    "statusBar.noFolderBackground": "#111111",
    "statusBar.debuggingBackground": "#111111",

    // ---- 标题栏 ----
    "titleBar.activeBackground": "#181818",
    "titleBar.activeForeground": "#e4e4e4",
    "titleBar.inactiveBackground": "#111111",
    "titleBar.inactiveForeground": "#4a4a4a",
    "titleBar.border": "#181818",

    // ---- 面板 (终端 / 输出) ----
    "panel.background": "#151515",
    "panel.border": "#181818",
    "panelTitle.activeForeground": "#e4e4e4",
    "panelTitle.inactiveForeground": "#4a4a4a",

    // ---- 列表 / 树 ----
    "list.activeSelectionBackground": "#2a2a2a",
    "list.activeSelectionForeground": "#e4e4e4",
    "list.inactiveSelectionBackground": "#222222",
    "list.inactiveSelectionForeground": "#e4e4e4",
    "list.hoverBackground": "#222222",
    "list.hoverForeground": "#e4e4e4",
    "list.focusBackground": "#2a2a2a",
    "list.focusForeground": "#e4e4e4",
    "list.highlightForeground": "#f43753",

    // ---- 输入框 / 下拉 ----
    "input.background": "#222222",
    "input.foreground": "#e4e4e4",
    "input.border": "#181818",
    "input.placeholderForeground": "#4a4a4a",
    "dropdown.background": "#222222",
    "dropdown.foreground": "#e4e4e4",
    "dropdown.border": "#181818",

    // ---- 按钮 ----
    "button.background": "#2a2a2a",
    "button.foreground": "#e4e4e4",
    "button.hoverBackground": "#3a3a3a",

    // ---- 滚动条 ----
    "scrollbarSlider.background": "#2a2a2a",
    "scrollbarSlider.hoverBackground": "#3a3a3a",
    "scrollbarSlider.activeBackground": "#4a4a4a",

    // ---- 边框/分割线 ----
    "editorGroup.border": "#181818",
    "editorGroupHeader.tabsBackground": "#151515",
    "tab.activeBackground": "#181818",
    "tab.inactiveBackground": "#151515",
    "tab.activeForeground": "#e4e4e4",
    "tab.inactiveForeground": "#4a4a4a",
    "tab.border": "#181818",
    "tab.activeBorder": "#f43753",

    // ---- 提示/通知 ----
    "notification.background": "#222222",
    "notification.foreground": "#e4e4e4",
    "notificationCenter.border": "#181818",
    "notificationToast.border": "#181818",

    // ---- 其他 ----
    "badge.background": "#f43753",
    "badge.foreground": "#e4e4e4",
    "progressBar.background": "#f43753",
    "editorWidget.background": "#222222",
    "editorWidget.border": "#181818"
  },

  // ============================================================
  // 以下 tokenColors 全部从 Emacs gruber-darker 主题中提取
  // 映射了 font-lock-* 等 faces 到对应的 TextMate scopes
  // ============================================================
  "tokenColors": [
    // 注释 (Comment) —— font-lock-comment-face
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#cc8c3c"   // gruber-darker-brown
        // 原主题注释无斜体，不设 fontStyle
      }
    },

    // 关键字 (Keyword) —— font-lock-keyword-face
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#ffdd33"   // gruber-darker-yellow
        // 原主题关键字为粗体，可取消注释下面一行启用：
        // "fontStyle": "bold"
      }
    },

    // 函数名 (Function) —— font-lock-function-name-face
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#96a6c8"   // gruber-darker-niagara
      }
    },

    // 类型名 (Type) —— font-lock-type-face
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#95a99f"   // gruber-darker-quartz
      }
    },

    // 字符串 (String) —— font-lock-string-face
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#73c936"   // gruber-darker-green
      }
    },

    // 数字、布尔、常量 —— font-lock-constant-face
    {
      "name": "Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.boolean"
      ],
      "settings": {
        "foreground": "#95a99f"   // 与类型同色
      }
    },

    // 变量、参数、成员 —— font-lock-variable-name-face
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other.member"
      ],
      "settings": {
        "foreground": "#f4f4ff"   // gruber-darker-fg+1
      }
    },

    // 内置函数 / 常量 —— font-lock-builtin-face
    {
      "name": "Built-in",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffdd33"   // 与关键字同色
      }
    },

    // 预处理器 —— font-lock-preprocessor-face
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#95a99f"   // 与类型同色
      }
    },

    // 错误 / 警告 —— font-lock-warning-face
    {
      "name": "Warning",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f43841"   // gruber-darker-red
      }
    },

    // 运算符 —— 保持与普通文本一致
    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#e4e4ef"   // gruber-darker-fg
      }
    },

    // 标点符号 —— 保持与普通文本一致
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#e4e4ef"   // gruber-darker-fg
      }
    }
  ]
}