{
  "$schema": "vscode://schemas/color-theme",
  "name": "Tsoding Emacs Dark (Gruber Darcula)",
  "type": "dark",
  "colors": {
    // ---- 编辑器核心（Darcula 原生编辑器底色 #2B2B2B）----
    "editor.background": "#2B2B2B",
    "editor.foreground": "#d8d8d8",
    "editor.lineHighlightBackground": "#323232",
    "editor.selectionBackground": "#404040",
    "editor.selectionHighlightBackground": "#363636",
    "editorCursor.foreground": "#82A8D9",
    "editorWhitespace.foreground": "#3A3A3A",
    "editorIndentGuide.background": "#323232",
    "editorIndentGuide.activeBackground": "#4A4A4A",
    "editorLineNumber.foreground": "#4A4A4A",
    "editorLineNumber.activeForeground": "#e4e4e4",
    "editorRuler.foreground": "#323232",
    "editorBracketMatch.background": "#323232",
    "editorBracketMatch.border": "#82A8D9",

    // ---- 侧边栏（Darcula 工具窗口底色 #3C3F41，与编辑区形成自然色差）----
    "sideBar.background": "#3C3F41",
    "sideBar.foreground": "#e4e4e4",
    "sideBarSectionHeader.background": "#353739",
    "sideBarSectionHeader.foreground": "#e4e4e4",
    "sideBarTitle.foreground": "#e4e4e4",
    "sideBar.border": "#2B2B2B",

    // ---- 活动栏 ----
    "activityBar.background": "#353739",
    "activityBar.foreground": "#e4e4e4",
    "activityBar.inactiveForeground": "#808080",
    "activityBar.border": "#2B2B2B",
    "activityBar.activeBorder": "#82A8D9",
    "activityBar.activeBackground": "#3C3F41",

    // ---- 状态栏 ----
    "statusBar.background": "#353739",
    "statusBar.foreground": "#e4e4e4",
    "statusBar.border": "#2B2B2B",
    "statusBar.noFolderBackground": "#353739",
    "statusBar.debuggingBackground": "#353739",

    // ---- 标题栏 ----
    "titleBar.activeBackground": "#2B2B2B",
    "titleBar.activeForeground": "#e4e4e4",
    "titleBar.inactiveBackground": "#353739",
    "titleBar.inactiveForeground": "#808080",
    "titleBar.border": "#2B2B2B",

    // ---- 面板 / 终端 ----
    "panel.background": "#3C3F41",
    "panel.border": "#2B2B2B",
    "panelTitle.activeForeground": "#e4e4e4",
    "panelTitle.inactiveForeground": "#808080",

    // ---- 列表 / 树（适配侧边栏底色）----
    "list.activeSelectionBackground": "#45494D",
    "list.activeSelectionForeground": "#e4e4e4",
    "list.inactiveSelectionBackground": "#3A3D40",
    "list.inactiveSelectionForeground": "#e4e4e4",
    "list.hoverBackground": "#3A3D40",
    "list.hoverForeground": "#e4e4e4",
    "list.focusBackground": "#45494D",
    "list.focusForeground": "#e4e4e4",
    "list.highlightForeground": "#82A8D9",

    // ---- 输入框 / 下拉 ----
    "input.background": "#353739",
    "input.foreground": "#e4e4e4",
    "input.border": "#2B2B2B",
    "input.placeholderForeground": "#808080",
    "dropdown.background": "#353739",
    "dropdown.foreground": "#e4e4e4",
    "dropdown.border": "#2B2B2B",

    // ---- 按钮 ----
    "button.background": "#45494D",
    "button.foreground": "#e4e4e4",
    "button.hoverBackground": "#505458",

    // ---- 滚动条 ----
    "scrollbarSlider.background": "#45494D",
    "scrollbarSlider.hoverBackground": "#505458",
    "scrollbarSlider.activeBackground": "#5A5E62",

    // ---- 标签栏与分割线 ----
    "editorGroup.border": "#2B2B2B",
    "editorGroupHeader.tabsBackground": "#3C3F41",
    "tab.activeBackground": "#2B2B2B",
    "tab.inactiveBackground": "#3C3F41",
    "tab.activeForeground": "#e4e4e4",
    "tab.inactiveForeground": "#808080",
    "tab.border": "#2B2B2B",
    "tab.activeBorder": "#82A8D9",

    // ---- 提示/通知 ----
    "notification.background": "#353739",
    "notification.foreground": "#e4e4e4",
    "notificationCenter.border": "#2B2B2B",
    "notificationToast.border": "#2B2B2B",

    // ---- 其他装饰元素 ----
    "badge.background": "#82A8D9",
    "badge.foreground": "#e4e4e4",
    "progressBar.background": "#82A8D9",
    "editorWidget.background": "#353739",
    "editorWidget.border": "#2B2B2B"
  },

  // ============================================================
  // 语法高亮：全量柔化 + 多语言支持补全
  // ============================================================
  "tokenColors": [
    // ---------- 通用基础高亮（全量压暗柔化）----------
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#b07a35"
      }
    },

    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#e6c72e"
      }
    },

    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#8a9abc"
      }
    },

    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },

    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#5ea832"
      }
    },

    {
      "name": "Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.boolean"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },

    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other.member"
      ],
      "settings": {
        "foreground": "#d3d3d5"
      }
    },

    {
      "name": "Built-in",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e6c72e"
      }
    },

    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },

    {
      "name": "Warning",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f43841"
      }
    },

    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#d8d8d8"
      }
    },

    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#cfcece"
      }
    },

    // ---------- JSON 文件专属高亮 ----------
    {
      "name": "JSON Property Key",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#8a9abc"
      }
    },
    {
      "name": "JSON Constant (true/false/null)",
      "scope": "constant.language.json",
      "settings": {
        "foreground": "#e6c72e"
      }
    },

    // ---------- SQL 文件专属高亮 ----------
    {
      "name": "SQL Keyword",
      "scope": [
        "keyword.sql",
        "keyword.ddl.sql",
        "keyword.dml.sql"
      ],
      "settings": {
        "foreground": "#e6c72e"
      }
    },
    {
      "name": "SQL Built-in Function",
      "scope": "support.function.sql",
      "settings": {
        "foreground": "#8a9abc"
      }
    },
    {
      "name": "SQL Table Name",
      "scope": "entity.name.table.sql",
      "settings": {
        "foreground": "#889a90"
      }
    },
    {
      "name": "SQL Column Name",
      "scope": "entity.name.column.sql",
      "settings": {
        "foreground": "#d3d3d5"
      }
    },

    // ---------- Markdown 文件专属高亮 ----------
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#e6c72e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#8a9abc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#b07a35",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link URL",
      "scope": "markup.link.url",
      "settings": {
        "foreground": "#5ea832",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown Link Text",
      "scope": "string.other.link.title.markdown",
      "settings": {
        "foreground": "#8a9abc"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#b07a35"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#5ea832"
      }
    },
    {
      "name": "Markdown List Bullet",
      "scope": "punctuation.definition.list.markdown",
      "settings": {
        "foreground": "#889a90"
      }
    }
  ]
}