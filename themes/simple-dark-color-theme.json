{
  "$schema": "vscode://schemas/color-theme",
  "name": "Tsoding Emacs Dark (Gruber)",
  "type": "dark",
  "colors": {
    // ---- 编辑器核心（背景为 Monokai 原生底色 #272822） ----
    "editor.background": "#272822",
    "editor.foreground": "#e4e4e4",
    "editor.lineHighlightBackground": "#2f302b",
    "editor.selectionBackground": "#3e3d32",
    "editor.selectionHighlightBackground": "#34352f",
    "editorCursor.foreground": "#c93c50",
    "editorWhitespace.foreground": "#3d3e38",
    "editorIndentGuide.background": "#2f302b",
    "editorIndentGuide.activeBackground": "#4a4b44",
    "editorLineNumber.foreground": "#4a4b44",
    "editorLineNumber.activeForeground": "#e4e4e4",
    "editorRuler.foreground": "#2f302b",
    "editorBracketMatch.background": "#2f302b",
    "editorBracketMatch.border": "#c93c50",

    // ---- 侧边栏 ----
    "sideBar.background": "#23241f",
    "sideBar.foreground": "#e4e4e4",
    "sideBarSectionHeader.background": "#272822",
    "sideBarSectionHeader.foreground": "#e4e4e4",
    "sideBarTitle.foreground": "#e4e4e4",
    "sideBar.border": "#272822",

    // ---- 活动栏 ----
    "activityBar.background": "#1e1f1c",
    "activityBar.foreground": "#e4e4e4",
    "activityBar.inactiveForeground": "#4a4b44",
    "activityBar.border": "#272822",
    "activityBar.activeBorder": "#c93c50",
    "activityBar.activeBackground": "#23241f",

    // ---- 状态栏 ----
    "statusBar.background": "#1e1f1c",
    "statusBar.foreground": "#e4e4e4",
    "statusBar.border": "#272822",
    "statusBar.noFolderBackground": "#1e1f1c",
    "statusBar.debuggingBackground": "#1e1f1c",

    // ---- 标题栏 ----
    "titleBar.activeBackground": "#272822",
    "titleBar.activeForeground": "#e4e4e4",
    "titleBar.inactiveBackground": "#1e1f1c",
    "titleBar.inactiveForeground": "#4a4b44",
    "titleBar.border": "#272822",

    // ---- 面板 (终端 / 输出) ----
    "panel.background": "#23241f",
    "panel.border": "#272822",
    "panelTitle.activeForeground": "#e4e4e4",
    "panelTitle.inactiveForeground": "#4a4b44",

    // ---- 列表 / 树 ----
    "list.activeSelectionBackground": "#2f302b",
    "list.activeSelectionForeground": "#e4e4e4",
    "list.inactiveSelectionBackground": "#292a25",
    "list.inactiveSelectionForeground": "#e4e4e4",
    "list.hoverBackground": "#292a25",
    "list.hoverForeground": "#e4e4e4",
    "list.focusBackground": "#2f302b",
    "list.focusForeground": "#e4e4e4",
    "list.highlightForeground": "#c93c50",

    // ---- 输入框 / 下拉 ----
    "input.background": "#292a25",
    "input.foreground": "#e4e4e4",
    "input.border": "#272822",
    "input.placeholderForeground": "#4a4b44",
    "dropdown.background": "#292a25",
    "dropdown.foreground": "#e4e4e4",
    "dropdown.border": "#272822",

    // ---- 按钮 ----
    "button.background": "#2f302b",
    "button.foreground": "#e4e4e4",
    "button.hoverBackground": "#3e3d32",

    // ---- 滚动条 ----
    "scrollbarSlider.background": "#2f302b",
    "scrollbarSlider.hoverBackground": "#3e3d32",
    "scrollbarSlider.activeBackground": "#4a4b44",

    // ---- 边框/分割线 ----
    "editorGroup.border": "#272822",
    "editorGroupHeader.tabsBackground": "#23241f",
    "tab.activeBackground": "#272822",
    "tab.inactiveBackground": "#23241f",
    "tab.activeForeground": "#e4e4e4",
    "tab.inactiveForeground": "#4a4b44",
    "tab.border": "#272822",
    "tab.activeBorder": "#c93c50",

    // ---- 提示/通知 ----
    "notification.background": "#292a25",
    "notification.foreground": "#e4e4e4",
    "notificationCenter.border": "#272822",
    "notificationToast.border": "#272822",

    // ---- 其他 ----
    "badge.background": "#c93c50",
    "badge.foreground": "#e4e4e4",
    "progressBar.background": "#c93c50",
    "editorWidget.background": "#292a25",
    "editorWidget.border": "#272822"
  },

  // ============================================================
  // 语法高亮完全保留原版，未做任何修改
  // ============================================================
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#cc8c3c"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#ffdd33"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#96a6c8"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#95a99f"
      }
    },
    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#73c936"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.boolean"
      ],
      "settings": {
        "foreground": "#95a99f"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other.member"
      ],
      "settings": {
        "foreground": "#f4f4ff"
      }
    },
    {
      "name": "Built-in",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffdd33"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#95a99f"
      }
    },
    {
      "name": "Warning",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f43841"
      }
    },
    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#e4e4ef"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#e4e4ef"
      }
    }
  ]
}
