{
  "$schema": "vscode://schemas/color-theme",
  "name": "Tsoding Emacs Dark (Gruber Darcula)",
  "type": "dark",
  "colors": {
    // ---- 编辑器核心（完全保留不变）----
    "editor.background": "#222222",
    "editor.foreground": "#d8d8d8",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editor.selectionBackground": "#383838",
    "editor.selectionHighlightBackground": "#2f2f2f",
    "editorCursor.foreground": "#82A8D9",
    "editorWhitespace.foreground": "#333333",
    "editorIndentGuide.background": "#2a2a2a",
    "editorIndentGuide.activeBackground": "#404040",
    "editorLineNumber.foreground": "#444444",
    "editorLineNumber.activeForeground": "#e4e4e4",
    "editorRuler.foreground": "#2a2a2a",
    "editorBracketMatch.background": "#2a2a2a",
    "editorBracketMatch.border": "#82A8D9",

    // ---- 侧边栏（完全保留不变）----
    "sideBar.background": "#2a2a2a",
    "sideBar.foreground": "#e4e4e4",
    "sideBarSectionHeader.background": "#262626",
    "sideBarSectionHeader.foreground": "#e4e4e4",
    "sideBarTitle.foreground": "#e4e4e4",
    "sideBar.border": "#222222",

    // ---- 活动栏（完全保留不变）----
    "activityBar.background": "#1f1f1f",
    "activityBar.foreground": "#e4e4e4",
    "activityBar.inactiveForeground": "#666666",
    "activityBar.border": "#222222",
    "activityBar.activeBorder": "#82A8D9",
    "activityBar.activeBackground": "#2a2a2a",

    // ---- 底部状态栏（完全保留不变）----
    "statusBar.background": "#1f1f1f",
    "statusBar.foreground": "#e4e4e4",
    "statusBar.border": "#222222",
    "statusBar.noFolderBackground": "#1f1f1f",
    "statusBar.debuggingBackground": "#1f1f1f",

    // ---- 顶部标题栏（Go 官方深青蓝，完全保留不变）----
    "titleBar.activeBackground": "#007894",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.inactiveBackground": "#005c72",
    "titleBar.inactiveForeground": "#d0d0d0",
    "titleBar.border": "#006982",

    // ---- 顶部菜单栏（配套同色系，完全保留不变）----
    "menu.background": "#006982",
    "menu.foreground": "#ffffff",
    "menu.selectionBackground": "#007894",
    "menu.selectionForeground": "#ffffff",
    "menu.border": "#005c72",

    // ---- 面板 / 终端（完全保留不变）----
    "panel.background": "#2a2a2a",
    "panel.border": "#222222",
    "panelTitle.activeForeground": "#e4e4e4",
    "panelTitle.inactiveForeground": "#666666",

    "terminal.background": "#222222",
    "terminal.foreground": "#d8d8d8",
    "terminal.selectionBackground": "#4a7ab8",
    "terminalCursor.foreground": "#82A8D9",
    "terminal.ansiBlack": "#1a1a1a",
    "terminal.ansiRed": "#b02b3d",
    "terminal.ansiGreen": "#5ea832",
    "terminal.ansiYellow": "#e6c72e",
    "terminal.ansiBlue": "#82A8D9",
    "terminal.ansiMagenta": "#a066b8",
    "terminal.ansiCyan": "#60b8d8",
    "terminal.ansiWhite": "#d8d8d8",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightRed": "#d13a4f",
    "terminal.ansiBrightGreen": "#73c936",
    "terminal.ansiBrightYellow": "#ffdd33",
    "terminal.ansiBrightBlue": "#96a6c8",
    "terminal.ansiBrightMagenta": "#b87ad0",
    "terminal.ansiBrightCyan": "#7fd0e8",
    "terminal.ansiBrightWhite": "#f0f0f0",

    // ---- 列表 / 树（完全保留不变）----
    "list.activeSelectionBackground": "#333333",
    "list.activeSelectionForeground": "#e4e4e4",
    "list.inactiveSelectionBackground": "#2d2d2d",
    "list.inactiveSelectionForeground": "#e4e4e4",
    "list.hoverBackground": "#2d2d2d",
    "list.hoverForeground": "#e4e4e4",
    "list.focusBackground": "#333333",
    "list.focusForeground": "#e4e4e4",
    "list.highlightForeground": "#82A8D9",

    // ---- 输入框 / 下拉（完全保留不变）----
    "input.background": "#2d2d2d",
    "input.foreground": "#e4e4e4",
    "input.border": "#222222",
    "input.placeholderForeground": "#666666",
    "dropdown.background": "#2d2d2d",
    "dropdown.foreground": "#e4e4e4",
    "dropdown.border": "#222222",

    // ---- 按钮（完全保留不变）----
    "button.background": "#333333",
    "button.foreground": "#e4e4e4",
    "button.hoverBackground": "#36454b",

    // ---- 滚动条（完全保留不变）----
    "scrollbarSlider.background": "#333333",
    "scrollbarSlider.hoverBackground": "#404040",
    "scrollbarSlider.activeBackground": "#4a4a4a",

    // ---- 标签栏与分割线（完全保留不变）----
    "editorGroup.border": "#222222",
    "editorGroupHeader.tabsBackground": "#2a2a2a",
    "tab.activeBackground": "#222222",
    "tab.inactiveBackground": "#2a2a2a",
    "tab.activeForeground": "#e4e4e4",
    "tab.inactiveForeground": "#666666",
    "tab.border": "#222222",
    "tab.activeBorder": "#007894",

    // ---- 提示/通知（完全保留不变）----
    "notification.background": "#2d2d2d",
    "notification.foreground": "#e4e4e4",
    "notificationCenter.border": "#222222",
    "notificationToast.border": "#222222",

    // ---- 其他装饰元素（完全保留不变）----
    "badge.background": "#82A8D9",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#82A8D9",
    "editorWidget.background": "#2d2d2d",
    "editorWidget.border": "#222222"
  },

  // ============================================================
  // 语法高亮：融入Go主题色 + YAML补全 + JSON/MD优化
  // ============================================================
  "tokenColors": [
    // ---------- 通用基础高亮（核心配色完全保留）----------
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#b07a35"
      }
    },

    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#e6c72e"
      }
    },

    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#8a9abc"
      }
    },

    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type.primitive"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },

    {
      "name": "String",
      "scope": "string",
      "settings": {
        "foreground": "#5ea832"
      }
    },

    {
      "name": "Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.boolean"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },

    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other.member"
      ],
      "settings": {
        "foreground": "#d3d3d5"
      }
    },

    // 内置函数/常量：改用Go主题青蓝色，区分普通关键字，丰富层次
    {
      "name": "Built-in",
      "scope": [
        "support.function.builtin",
        "support.constant"
      ],
      "settings": {
        "foreground": "#52b7d2"
      }
    },

    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },

    {
      "name": "Warning",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#f43841"
      }
    },

    {
      "name": "Operator",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#d8d8d8"
      }
    },

    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#cfcece"
      }
    },

    // ---------- JSON 文件专属高亮（键名改用Go主题色）----------
    {
      "name": "JSON Property Key",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#52b7d2"
      }
    },
    {
      "name": "JSON Constant (true/false/null)",
      "scope": "constant.language.json",
      "settings": {
        "foreground": "#e6c72e"
      }
    },

    // ---------- YAML 文件专属高亮（全新补全）----------
    {
      "name": "YAML Key",
      "scope": "entity.name.tag.yaml",
      "settings": {
        "foreground": "#52b7d2"
      }
    },
    {
      "name": "YAML Constant",
      "scope": [
        "constant.language.yaml",
        "constant.numeric.yaml",
        "constant.other.timestamp.yaml"
      ],
      "settings": {
        "foreground": "#889a90"
      }
    },
    {
      "name": "YAML String",
      "scope": "string.yaml",
      "settings": {
        "foreground": "#5ea832"
      }
    },
    {
      "name": "YAML Anchor & Alias",
      "scope": [
        "variable.other.anchor.yaml",
        "variable.other.alias.yaml"
      ],
      "settings": {
        "foreground": "#e6c72e"
      }
    },
    {
      "name": "YAML Punctuation",
      "scope": [
        "punctuation.definition.mapping.yaml",
        "punctuation.definition.sequence.yaml",
        "punctuation.definition.string.yaml"
      ],
      "settings": {
        "foreground": "#cfcece"
      }
    },

    // ---------- SQL 文件专属高亮（完全保留）----------
    {
      "name": "SQL Keyword",
      "scope": [
        "keyword.sql",
        "keyword.ddl.sql",
        "keyword.dml.sql"
      ],
      "settings": {
        "foreground": "#e6c72e"
      }
    },
    {
      "name": "SQL Built-in Function",
      "scope": "support.function.sql",
      "settings": {
        "foreground": "#52b7d2"
      }
    },
    {
      "name": "SQL Table Name",
      "scope": "entity.name.table.sql",
      "settings": {
        "foreground": "#889a90"
      }
    },
    {
      "name": "SQL Column Name",
      "scope": "entity.name.column.sql",
      "settings": {
        "foreground": "#d3d3d5"
      }
    },

    // ---------- Markdown 文件专属高亮（融入主题色优化）----------
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#e6c72e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#8a9abc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#b07a35",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link URL",
      "scope": "markup.link.url",
      "settings": {
        "foreground": "#5ea832",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown Link Text",
      "scope": "string.other.link.title.markdown",
      "settings": {
        "foreground": "#52b7d2"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": "markup.quote",
      "settings": {
        "foreground": "#b07a35"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#5ea832"
      }
    },
    {
      "name": "Markdown List Bullet",
      "scope": "punctuation.definition.list.markdown",
      "settings": {
        "foreground": "#52b7d2"
      }
    }
  ]
}