{
  "$schema": "vscode://schemas/color-theme",
  "name": "go-c-navy-deep-dark",
  "type": "dark",
  "colors": {
    // --- 编辑器基础 UI (保持深蓝冷色调) ---
    "editor.background": "#151720",
    "editor.foreground": "#abb2bf",
    "editorLineNumber.foreground": "#4b526d",
    "editorLineNumber.activeForeground": "#abb2bf",
    "editor.lineHighlightBackground": "#1c1f2b",
    "editor.selectionBackground": "#3e4451",
    "editorCursor.foreground": "#528bff",
    
    "sideBar.background": "#12141a",
    "sideBar.foreground": "#abb2bf",
    "sideBarSectionHeader.background": "#181a24",
    
    "panel.background": "#12141a",
    "panel.border": "#181a24",
    "panelTitle.activeForeground": "#ffffff",
    
    "statusBar.background": "#21252b",
    "statusBar.foreground": "#abb2bf",
    
    "titleBar.activeBackground": "#12141a",
    "titleBar.activeForeground": "#cccccc"
  },
  "tokenColors": [
    // 1. 注释：暗灰色
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#5c6370"
      }
    },
    
    // 2. 核心关键字 (Control & Declaration)
    // 涵盖：Go (func, type, struct, interface, map, chan, package, import) 
    // 涵盖：C (typedef, struct, enum, union, return, if, for)
    // 颜色：紫红色 (#c678dd) - 这是您想要的特殊颜色
    {
      "name": "Keywords (Control & Declaration)",
      "scope": [
        "keyword.control",
        "keyword.declaration",
        "storage.type", 
        "storage.modifier",
        "keyword.other.new",
        "keyword.other.this",
        "keyword.package.go",
        "keyword.import.go",
        "keyword.function.go", 
        "keyword.type.go",
        "keyword.struct.go",
        "keyword.interface.go",
        "keyword.map.go",
        "keyword.chan.go"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#c678dd"
      }
    },

    // 3. 运算符
    // 颜色：青色 (#56b6c2)
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },

    // 4. 函数名 (Function Names)
    // 涵盖：Go (func MyFunc), C (void MyFunc)
    // 颜色：亮蓝色 (#61afef) - 最醒目的颜色
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#61afef"
      }
    },

    // 5. 类型名 (Types)
    // 涵盖：Go (int, string, bool, MyStruct), C (int, u32, matrix*, size_t)
    // 颜色：金黄色 (#e5c07b)
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type",
        "storage.type.primitive",
        "entity.name.type.alias.go", 
        "entity.name.type.struct.go",
        "entity.name.type.interface.go"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#e5c07b"
      }
    },

    // 6. 包名 / 命名空间 / 接收者变量
    // 涵盖：Go (fmt.Println 中的 fmt, s.Method 中的 s), C (std::, mat->)
    // 颜色：青绿色 (#56b6c2) - 用于区分函数名和它所属的域
    {
      "name": "Packages / Receivers / Namespaces",
      "scope": [
        "variable.other.readwrite",
        "variable.parameter",
        "variable.other.member",
        "entity.name.namespace",
        "variable.language.receiver.go" 
      ],
      "settings": {
        "foreground": "#abb2bf" 
      }
    },
    
    // 专门针对 Go 的包名高亮 (如果语法支持)
    {
      "name": "Go Package Names",
      "scope": [
        "entity.name.package.go"
      ],
      "settings": {
        "foreground": "#56b6c2"
      }
    },

    // 7. 字符串
    // 颜色：绿色 (#98c379)
    {
      "name": "Strings",
      "scope": "string",
      "settings": {
        "fontStyle": "",
        "foreground": "#98c379"
      }
    },

    // 8. 数字 / 布尔值 / 常量
    // 颜色：橙色 (#d19a66)
    {
      "name": "Constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.boolean",
        "variable.other.enummember",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#d19a66"
      }
    },

    // 9. 预处理器 (C/C++)
    // 颜色：红色 (#e06c75)
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.import",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#e06c75"
      }
    },

    // 10. 标点符号
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.definition"
      ],
      "settings": {
        "foreground": "#abb2bf"
      }
    }
  ]
}