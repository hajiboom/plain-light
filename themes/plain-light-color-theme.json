{
  "$schema": "vscode://schemas/color-theme",
  "name": "plain-light",
  "type": "light",
  "colors": {
    "editor.background": "#f8f8f8",
    "editor.foreground": "#333333",
    "editorLineNumber.foreground": "#888888",
    "editorLineNumber.activeForeground": "#000000",
    "editor.lineHighlightBackground": "#f0f0f0",
    "editor.selectionBackground": "#e0e0e0",
    "sideBar.background": "#f5f5f5",
    "sideBar.foreground": "#333333",

    // ========== 顶部标题栏 全新柔和配色 ==========
    "titleBar.activeBackground": "#d6e4e7",
    "titleBar.activeForeground": "#2c3e40",
    "titleBar.inactiveBackground": "#b8c8cc",
    "titleBar.inactiveForeground": "#607275",
    "titleBar.border": "#c2d2d6",

    "menu.background": "#e1eced",
    "menu.foreground": "#2c3e40",
    "menu.selectionBackground": "#c8dadd",
    "menu.selectionForeground": "#1a282a",
    "menu.border": "#b0c4c8",

    // ========== 底部状态栏 全新柔和配色 ==========
    "statusBar.background": "#c9dcdf",
    "statusBar.foreground": "#2c3e40",
    "statusBar.border": "#a9bfc3",
    "statusBar.debuggingBackground": "#e6cdb8",

    "panel.background": "#f0f0f0",
    "panel.border": "#d1bcbc",
    "panelTitle.activeForeground": "#333333",
    "panelTitle.inactiveForeground": "#888888",

    "terminal.background": "#f0f0f0",
    "terminal.foreground": "#222222",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#a31515",
    "terminal.ansiGreen": "#608b4e",
    "terminal.ansiYellow": "#d7ba7d",
    "terminal.ansiBlue": "#000080",
    "terminal.ansiMagenta": "#7A3E9D",
    "terminal.ansiCyan": "#267f99",
    "terminal.ansiWhite": "#cccccc",
    "editor.findMatchBackground": "#ffffe0",
    "list.activeSelectionIconForeground": "#fff"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#608b4e"
      }
    },
    {
      "name": "Keywords (Control)",
      "scope": [
        "keyword.control",
        "keyword.declaration",
        "storage.modifier",
        "keyword.other.new",
        "keyword.other.this",
        "keyword.other.func"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#07a6bb"
      }
    },
    {
      "name": "Go Func Keyword",
      "scope": [
        "keyword.other.func",
        "source.go keyword.func",
        "meta.function.declaration.go keyword.other.func"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#07a6bb"
      }
    },
    {
      "name": "Keywords (Operator/Logic)",
      "scope": [
        "keyword.operator.logical",
        "keyword.operator.comparison"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7A3E9D"
      }
    },
    {
      "name": "Strings",
      "scope": "string",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#b49508"
      }
    },
    {
      "name": "Operators & Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#333333"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.other.inherited-class",
        "source.go entity.name.type.struct",
        "source.go entity.name.type.interface"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#267f99"
      }
    },
    {
      "name": "Custom Functions/Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "source.go entity.name.function"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#910c4e"
      }
    },
    {
      "name": "Invalid Syntax",
      "scope": "invalid",
      "settings": {
        "fontStyle": "",
        "foreground": "#ff0000"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#000080"
      }
    },
    {
      "name": "CSS",
      "scope": [
        "meta.selector",
        "meta.property-name",
        "meta.property-value"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7A3E9D"
      }
    },
    {
      "name": "Diff",
      "scope": [
        "meta.diff.range",
        "meta.diff.header.from-file",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#333333"
      }
    }
  ]
}
